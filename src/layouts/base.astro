---
import '~/css/main.css';
import 'virtual:sugarcube.css';

import Footer from '~/components/site/footer.astro';
import Header from '~/components/site/header.astro';
import Seo, { type Props as SeoProps } from '~/components/site/seo.astro';

export interface Props extends SeoProps {}
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="shortcut icon" href="/favicon.ico" type="image/x-icon" />
		<Seo {...Astro.props} />

		<!-- Webmentions -->
		<link rel="webmention" href="https://webmention.io/binyam.in/webmention" />
		<link rel="pingback" href="https://webmention.io/binyam.in/xmlrpc" />

		<!-- microsub -->
		<link rel="microsub" href="https://aperture.p3k.io/microsub/680" />

		<!-- Indieauth -->
		<link rel="authorization_endpoint" href="https://indieauth.com/auth" />
		<link rel="token_endpoint" href="https://tokens.indieauth.com/token" />

		<slot name="head" />
	</head>
	<body>
		<Header />
		<main>
			<slot />
		</main>
		<Footer />
	</body>
</html>
